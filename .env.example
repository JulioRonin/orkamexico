# ===== Vite/Frontend (públicas, expuestas al cliente) =====
# Copia este archivo a .env.local y llena los valores
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# ===== Server-side (NUNCA exponer al cliente, solo scripts/ETL) =====
# Usado solo por scripts en /scripts (ETL, migrations manuales)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
